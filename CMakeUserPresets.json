{
    "version": 4,
    "vendor": {
        "conan": {}
    },
    "include": [
        "build/Release/generators/CMakePresets.json",
        "cmake-build-debug/build/Debug/generators/CMakePresets.json"
    ],
    "configurePresets": [
        {
            "name": "clion-release",
            "inherits": "conan-release",
            "displayName": "CLion Release",
            "cacheVariables": {
                "DEV_MODE": "ON",
                "BISON_EXECUTABLE": "/opt/homebrew/opt/bison/bin/bison"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "clion-release",
            "configurePreset": "clion-release",
            "jobs": 12
        }
    ],
    "testPresets": [
        {
            "name": "clion-release",
            "configurePreset": "clion-release",
            "execution": {
                "jobs": 12
            }
        }
    ]
}